# ============================================
# LiveKit Connection
# ============================================
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret
SIP_TRUNK_ID=your_sip_trunk_id

# ============================================
# AI Models & Services
# ============================================
# Groq LLM (OpenAI-compatible, free tier)
GROQ_API_KEY=gsk_your_groq_api_key

# Deepgram STT (Speech-to-Text)
DEEPGRAM_API_KEY=your_deepgram_api_key

# Sarvam TTS (Text-to-Speech - Primary, Hindi/Hinglish)
SARVAM_API_KEY=your_sarvam_api_key

# ElevenLabs TTS (Text-to-Speech - Premium fallback)
ELEVEN_API_KEY=your_elevenlabs_api_key

# ============================================
# Google Integrations
# ============================================
GOOGLE_SHEET_ID=your_google_sheet_id
GOOGLE_WORKSHEET_NAME=Leads
GOOGLE_OAUTH_CREDENTIALS_FILE=credentials.json
GOOGLE_CALENDAR_ID=primary
